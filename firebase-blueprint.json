{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile inside PublicEye",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "name": { "type": "string" },
        "area": { "type": "string" },
        "joinDate": { "type": "string" },
        "postsCount": { "type": "integer" },
        "falsePostCount": { "type": "integer" },
        "spamBehavior": { "type": "boolean" },
        "deviceFingerprint": { "type": "string" },
        "isFlagged": { "type": "boolean" }
      },
      "required": ["id", "phoneNumber", "name", "area", "joinDate", "postsCount", "falsePostCount", "spamBehavior", "deviceFingerprint", "isFlagged"]
    },
    "IncidentPost": {
      "title": "IncidentPost",
      "description": "An incident post representing public alert or civic issue",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["Alert", "Civic"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "photoUrl": { "type": "string" },
        "locationName": { "type": "string" },
        "category": { "type": "string" },
        "severity": { "type": "string" },
        "isAnonymous": { "type": "boolean" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userArea": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isArchived": { "type": "boolean" },
        "reportedCount": { "type": "integer" },
        "expireTime": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "title", "description", "locationName", "isAnonymous", "userId", "userName", "userArea", "timestamp", "isArchived", "reportedCount", "expireTime"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment left on an incident post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "content": { "type": "string" },
        "photoUrl": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isAnonymous": { "type": "boolean" },
        "isUpdate": { "type": "boolean" },
        "reportedCount": { "type": "integer" }
      },
      "required": ["id", "postId", "userId", "userName", "content", "timestamp", "isAnonymous", "isUpdate", "reportedCount"]
    }
  },
  "firestore": {
    "profiles/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles indexed by their auth IDs"
    },
    "posts/{postId}": {
      "schema": "IncidentPost",
      "description": "Feed item alerts and civic issues"
    },
    "posts/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments and status updates on specific posts"
    }
  }
}
