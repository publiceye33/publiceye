rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global safety net (Default Deny Catch-all)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY PRIMITIVES ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedUser() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      // Bootstrapped administrator checking the verified runtime user address
      return isSignedIn() && 
        (request.auth.token.email == "publiceye33@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    type_checking_is_not_supported_as_this_comment_and_syntax_above {
      // Dummy rule to demonstrate helper separation
    }

    // --- COLLECTION RULES & SCHEMAS ---

    // USER PROFILES
    match /profiles/{userId} {
      allow read: if isSignedIn();
      
      allow create: if isSignedIn() && request.auth.uid == userId && isValidProfile(incoming());
      
      allow update: if isSignedIn() && (
        isAdmin() || (
          request.auth.uid == userId && 
          isValidProfile(incoming()) && 
          incoming().falsePostCount == existing().falsePostCount && 
          incoming().isFlagged == existing().isFlagged
        )
      );

      allow delete: if isAdmin();

      function isValidProfile(data) {
        return data.keys().hasAll(['id', 'phoneNumber', 'name', 'area', 'joinDate', 'postsCount', 'falsePostCount', 'spamBehavior', 'deviceFingerprint', 'isFlagged'])
          && data.keys().size() == 10
          && data.id == request.auth.uid
          && data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.phoneNumber is string && data.phoneNumber.size() <= 20
          && data.area is string && data.area.size() <= 100
          && data.joinDate is string && data.joinDate.size() <= 30
          && data.postsCount is int
          && data.falsePostCount is int
          && data.spamBehavior is bool
          && data.deviceFingerprint is string && data.deviceFingerprint.size() <= 200
          && data.isFlagged is bool;
      }
    }

    // INCIDENT POSTS
    match /posts/{postId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // client uses proper sorting/feed bounds; rule-enforced on data shapes
      
      allow create: if isSignedIn() && isValidPost(incoming()) && 
        incoming().userId == request.auth.uid &&
        incoming().reportedCount == 0 && 
        incoming().isArchived == false;

      allow update: if isSignedIn() && (
        isAdmin() || (
          isValidPost(incoming()) && (
            // Action 1: Support / Votes array modified
            (incoming().diff(existing()).affectedKeys().hasOnly(['votes'])) ||
            
            // Action 2: Incremental Report Report Post Count +1
            (incoming().diff(existing()).affectedKeys().hasOnly(['reportedCount']) && incoming().reportedCount == existing().reportedCount + 1) ||
            
            // Action 3: Extend Expiry when timer lapses
            (incoming().diff(existing()).affectedKeys().hasOnly(['expireTime', 'isArchived'])) ||
            
            // Action 4: Edit description (Original poster editing their text)
            (existing().userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'photoUrl', 'category', 'severity']))
          )
        )
      );

      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);

      function isValidPost(data) {
        return data.keys().hasAll(['id', 'type', 'title', 'description', 'locationName', 'isAnonymous', 'userId', 'userName', 'userArea', 'timestamp', 'isArchived', 'reportedCount', 'expireTime'])
          && data.id is string && data.id.size() <= 128
          && data.type is string && (data.type == 'Alert' || data.type == 'Civic')
          && data.title is string && data.title.size() > 0 && data.title.size() <= 150
          && data.description is string && data.description.size() > 0 && data.description.size() <= 4000
          && data.locationName is string && data.locationName.size() <= 150
          && data.isAnonymous is bool
          && data.userId is string && data.userId.size() <= 128
          && data.userName is string && data.userName.size() <= 100
          && data.userArea is string && data.userArea.size() <= 100
          && data.timestamp is string && data.timestamp.size() <= 35
          && data.isArchived is bool
          && data.reportedCount is int
          && data.expireTime is string && data.expireTime.size() <= 35
          && (!('category' in data) || (data.category is string && data.category.size() <= 50))
          && (!('severity' in data) || (data.severity is string && data.severity.size() <= 20))
          && data.votes is list && data.votes.size() <= 2000;
      }

      // SUBCOLLECTION: COMMENTS AND UPDATES
      match /comments/{commentId} {
        allow read: if isSignedIn();

        allow create: if isSignedIn() && isValidComment(incoming()) && 
          incoming().postId == postId && 
          incoming().userId == request.auth.uid &&
          incoming().reportedCount == 0;

        allow update: if isSignedIn() && (
          isAdmin() || (
            // Owner editing comment text
            (existing().userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['content']) && isValidComment(incoming())) ||
            // Anyone reporting comment
            (incoming().diff(existing()).affectedKeys().hasOnly(['reportedCount']) && incoming().reportedCount == existing().reportedCount + 1)
          )
        );

        allow delete: if isSignedIn() && (
          isAdmin() || 
          existing().userId == request.auth.uid || 
          get(/databases/$(database)/documents/posts/$(postId)).data.userId == request.auth.uid
        );

        function isValidComment(data) {
          return data.keys().hasAll(['id', 'postId', 'userId', 'userName', 'content', 'timestamp', 'isAnonymous', 'isUpdate', 'reportedCount'])
            && data.id is string && data.id.size() <= 128
            && data.postId is string && data.postId.size() <= 128
            && data.userId is string && data.userId.size() <= 128
            && data.userName is string && data.userName.size() <= 100
            && data.content is string && data.content.size() > 0 && data.content.size() <= 2000
            && data.timestamp is string && data.timestamp.size() <= 35
            && data.isAnonymous is bool
            && data.isUpdate is bool
            && data.reportedCount is int
            && (!('photoUrl' in data) || (data.photoUrl is string && data.photoUrl.size() <= 1000));
        }
      }
    }
  }
}
